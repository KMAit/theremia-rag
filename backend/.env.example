# ── Providers (default: 0€ local mode) ───────────────────────────────────────
# Supported LLM providers: openai | openrouter | ollama
LLM_PROVIDER=ollama

# Supported embeddings providers: openai | huggingface
EMBEDDINGS_PROVIDER=huggingface

# ── Ollama (0€ local LLM) ────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── HuggingFace embeddings (0€ local embeddings) ─────────────────────────────
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── OpenAI (optional paid) ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# DEFAULT_LLM_MODEL=gpt-4o-mini
# DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# ── OpenRouter (optional paid) ───────────────────────────────────────────────
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# DEFAULT_LLM_MODEL=gpt-4o-mini

# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./theremia.db

# ── Storage ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── RAG ──────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Proxy / networking ───────────────────────────────────────────────────────
TRUST_PROXY_HEADERS=false